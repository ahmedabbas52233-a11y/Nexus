PORT=5000
NODE_ENV=development

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

# Comma-separated list of allowed frontend origins (used for CORS + password reset links)
FRONTEND_URL=http://localhost:5173

# Optional: real SMTP credentials for sending password-reset/2FA emails.
# If left unset, emails are logged to the server console instead (safe for local dev/demo).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Nexus Platform <no-reply@nexus.app>

# Optional: override where the SQLite DB and uploaded files are written.
# Leave unset for local dev (defaults to backend/nexus.db and backend/uploads/).
# Set these to a mounted volume path in production if your host supports one
# (e.g. Fly.io: DB_PATH=/data/nexus.db, UPLOADS_DIR=/data/uploads).
DB_PATH=
UPLOADS_DIR=
